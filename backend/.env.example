# --- App ---
APP_NAME=NexusAI
APP_ENV=development
DEBUG=true
API_V1_PREFIX=/api/v1
LOG_LEVEL=INFO

# --- Security / JWT ---
JWT_SECRET_KEY=change-me-to-a-random-64-char-string
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# --- CORS (comma-separated origins) ---
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# --- PostgreSQL ---
POSTGRES_USER=nexus
POSTGRES_PASSWORD=nexus_password
POSTGRES_DB=nexusai
DATABASE_URL=postgresql+asyncpg://nexus:nexus_password@postgres:5432/nexusai

# --- Redis ---
REDIS_URL=redis://redis:6379/0

# --- Qdrant ---
QDRANT_HOST=qdrant
QDRANT_PORT=6333
QDRANT_COLLECTION_NAME=nexus_documents
EMBEDDING_DIM=384

# --- Embeddings ---
EMBEDDING_MODEL_NAME=BAAI/bge-small-en-v1.5

# --- LLM (RAG answer generation) ---
LLM_PROVIDER=groq
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL_NAME=llama-3.1-8b-instant

# --- File uploads ---
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=20

# --- Chunking ---
CHUNK_SIZE=1000
CHUNK_OVERLAP=150
